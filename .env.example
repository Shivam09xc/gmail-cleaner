# =============================================
#  YAHAN APNI VALUES DAALO — COPY KARO .env.local
# =============================================

# Google OAuth (Google Cloud Console se milega)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# NextAuth Secret — koi bhi random 32+ character string
# Generate karne ke liye terminal mein chalao: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Apni website ka URL (development mein yeh rakho, production mein Vercel URL)
NEXTAUTH_URL=http://localhost:3000
